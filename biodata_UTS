        let isAnimating = false;
        function loadPage(pageId) {
            if(isAnimating) return;
            isAnimating = true;
            const contentDiv = document.getElementById('mainContent');
            contentDiv.style.opacity = '0';
            contentDiv.style.transform = 'translateY(8px)';
            setTimeout(() => {
                let newContent = '';
                if(pageId === 'home') newContent = getHalamanHome();
                else if(pageId === 'about') newContent = getHalamanAbout();
                else if(pageId === 'kontak') newContent = getHalamanKontak();
                else newContent = getHalamanHome();
                contentDiv.innerHTML = newContent;
                contentDiv.style.transition = 'opacity 0.25s ease, transform 0.3s cubic-bezier(0.2,0.9,0.4,1.1)';
                contentDiv.style.opacity = '1';
                contentDiv.style.transform = 'translateY(0)';
                setTimeout(() => { isAnimating = false; }, 300);
            }, 160);
        }

        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const page = link.getAttribute('data-page');
                if(page === 'home') loadPage('home');
                else if(page === 'about') loadPage('about');
                else if(page === 'kontak') loadPage('kontak');
                document.querySelectorAll('.nav-link').forEach(l => l.style.background = '#f4a261');
                link.style.background = '#e76f51';
            });
        });

        loadPage('home');
        setTimeout(() => {
            const homeBtn = document.querySelector('.nav-link[data-page="home"]');
            if(homeBtn) homeBtn.style.background = '#e76f51';
        }, 50);
