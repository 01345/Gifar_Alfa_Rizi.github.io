    <style>
        /* GAYA EKSTERNAL dengan BACKGROUND ESTETIK LUCU */
        :root {
            --bg-gradient: linear-gradient(135deg, #fff9f0 0%, #ffe6f0 50%, #e0f3ff 100%);
            --card-bg: rgba(255, 255, 250, 0.92);
            --text-dark: #333b4d;
            --primary: #f4a261;
            --secondary: #e76f51;
            --soft-pink: #ffb7b2;
            --soft-blue: #a0d2e4;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Poppins', 'Quicksand', system-ui, Arial, sans-serif;
            background-image: url('https://images.unsplash.com/photo-1572375992501-4b0892d50c69?w=1600'), linear-gradient(145deg, #fff5f0, #ffe6ed);
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-blend-mode: overlay;
            color: var(--text-dark);
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            min-height: 100vh;
        }

        h1, h2, h3 {
            font-weight: 700;
            letter-spacing: -0.3px;
        }

        .judul-utama {
            text-align: center;
            font-size: 2.8rem;
            background: linear-gradient(135deg, #e76f51, #f4a261, #e9c46a);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 10px;
            animation: gentleFloat 3s ease-in-out infinite;
        }

        @keyframes gentleFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }

        .navbar {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
            margin: 30px 0 35px;
        }

        .nav-link {
            background: #f4a261;
            color: white;
            padding: 12px 32px;
            border-radius: 60px;
            text-decoration: none;
            font-weight: bold;
            font-size: 1.1rem;
            transition: all 0.25s ease;
            box-shadow: 0 4px 0 #c06c3c;
            cursor: pointer;
            display: inline-block;
        }

        .nav-link:hover {
            transform: translateY(-3px);
            background: #e76f51;
            box-shadow: 0 8px 12px rgba(0,0,0,0.2);
        }

        .page-container {
            animation: fadeInUp 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Tabel */
        .table-riwayat {
            width: 100%;
            border-collapse: collapse;
            border-radius: 24px;
            overflow: hidden;
            background: white;
            box-shadow: 0 4px 14px rgba(0,0,0,0.05);
        }
        .table-riwayat th {
            background: #e76f51;
            color: white;
            padding: 12px 10px;
        }
        .table-riwayat td {
            padding: 10px;
            border-bottom: 1px solid #ffe0e6;
            color: #444c5c;
        }
        .table-riwayat tr:hover {
            background: #fff0f5;
            transition: 0.2s;
        }

        /* Card */
        .card-modern {
            background: rgba(255, 252, 245, 0.94);
            backdrop-filter: blur(3px);
            border-radius: 48px;
            padding: 25px 30px;
            box-shadow: 0 20px 35px -10px rgba(0,0,0,0.1), 0 0 0 8px rgba(255,215,200,0.3);
            border: 2px solid rgba(255,235,220,0.8);
        }

        .btn-kontak {
            background: #e9c46a;
            color: #333;
            padding: 8px 18px;
            border-radius: 30px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.2s;
        }
        .btn-kontak:hover {
            background: #f4a261;
            transform: scale(1.02);
        }

        .sosial-item {
            transition: transform 0.2s, box-shadow 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 600;
            text-decoration: none;
            color: white;
        }
        .sosial-item:hover {
            transform: translateY(-4px);
            filter: brightness(1.05);
        }

        .grid-profil {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-top: 25px;
        }
        .icon-badge {
            font-size: 1.8rem;
            display: block;
        }
        .foto-profil {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid #f4a261;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
    </style>
</head>
